{
  "name": "agent-studio-mockup",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Studio desktop app mockup built with React 19 and Electron.",
  "author": "domaingts",
  "desktopName": "Agent Studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/domaingts/ClaudeCodeRev.git",
    "directory": "image"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.cjs && electronmon dist-electron/main.cjs",
    "dev:desktop": "concurrently -k \"npm:dev\" \"npm:dev:electron:build\" \"npm:dev:electron\"",
    "build:web": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:web && npm run build:electron",
    "pack": "npm run build && electron-builder --dir",
    "dist:desktop": "npm run build && electron-builder",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electronmon": "^2.0.3",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1"
  }
}
